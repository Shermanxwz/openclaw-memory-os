# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtualenvs
.venv/
venv/
env/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Logs
*.log

# Local env files (the example is checked in; real ones are not)
.env
.env.local

# OS-level artefacts that should not be published
memory_os.local.json
qdrant_local.json
.secrets/
scripts/reindex-watchdog.sh

# Personal taxonomy (operator-specific brand / keyword lists). The real
# config file is gitignored; the *.example.json template is checked in so
# fork operators can see the schema without leaking their own taxonomy.
config/personal_taxonomy.json
config/personal_taxonomy.local.json

# Local-maintenance / audit artefacts from prior deployment waves.
# These are intentionally untracked; if a wave genuinely needs one
# in git, force-add it explicitly. Without these patterns every
# wave re-pollutes `git status` with housekeeping noise.
.audit-*/
.cleanup-*/

# Backup / pre-fix snapshots left behind by edit waves. Recoverable
# from the archive directory listed in the release-hygiene playbook
# if anything needs to come back; otherwise they are dead weight.
*.bak
*.pre
*.pre-*
*.prebugfix-*
