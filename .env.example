# OpenClaw Memory OS · example environment file.
#
# Copy this file to `.env` and adjust the values. The OS does NOT auto-load
# `.env`; either export the vars yourself or set `MEMORY_OS_ENV_FILE` to the
# absolute path of this file before starting the server.

# Auth: a single shared bearer token. If unset, auth is disabled (useful for
# local development and CI). Do NOT commit a real value to the repo.
# Generate a strong token, e.g.:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
MEMORY_OS_TOKEN=

# Optional layered auth: when MEMORY_OS_PASSWORD is set the login form
# upgrades to a two-step challenge (password + 6-digit TOTP). Set both
# MEMORY_OS_PASSWORD and MEMORY_OS_TOTP_SECRET to require TOTP. The TOTP
# secret is the standard base32 string shown in your authenticator app
# (e.g. `JBSWY3DPEHPK3PXP`). Leave MEMORY_OS_PASSWORD empty to keep the
# legacy bearer-token-only mode.
# MEMORY_OS_PASSWORD=
# MEMORY_OS_TOTP_SECRET=

# Session cookie lifetime in seconds. Default 12 hours.
# MEMORY_OS_SESSION_MAX_AGE=43200

# Public-facing port the app is served on. The systemd unit in
# deploy/systemd/openclaw-memory-os.service binds uvicorn to 127.0.0.1:7788
# and the rendered nginx vhost proxies public traffic to that port. Changing
# the production port requires matching systemd/nginx edits.
MEMORY_OS_PORT=7788

# Public DNS hostname used by deploy/deploy.sh for nginx and TLS. The deployer
# refuses the placeholder; set the real hostname before production install.
MEMORY_OS_DOMAIN=memory-os.example.com

# Storage backend. If QDRANT_URL is unset, the bundled JSON sample backend
# (data/sample_memories.json) is used.
QDRANT_URL=
QDRANT_COLLECTION=openclaw_memory_os
QDRANT_API_KEY=

# Override the sample data file path (used when QDRANT_URL is empty).
# MEMORY_OS_SAMPLE_PATH=/absolute/path/to/sample_memories.json

# Ranking tunables. Sensible defaults; tweak for your data shape.
MEMORY_OS_MAX_RECALL=25
MEMORY_OS_RECENCY_HALF_LIFE=30
MEMORY_OS_SUPERSEDED_PENALTY=0.25
MEMORY_OS_EXPIRED_PENALTY=0.10
MEMORY_OS_IMPORTANCE_BOOST=0.6

# Recall fallback strategy. When the active-only pass yields fewer than
# RECALL_FALLBACK_SUPERSEDED_MIN_RESULTS hits, the recall API/CLI
# automatically expands the search to include superseded memories as
# lower-priority results. Set RECALL_FALLBACK_SUPERSEDED=off to disable.
# Note: an explicit ``include_superseded=true`` in a recall request always
# wins and bypasses the fallback logic.
RECALL_FALLBACK_SUPERSEDED=on
RECALL_FALLBACK_SUPERSEDED_MIN_RESULTS=5

# ---------------------------------------------------------------------------
# v0.3.0.x feature flags
# ---------------------------------------------------------------------------
# Each flag has a safe default that preserves the previous behaviour, so a
# missing env var never changes runtime semantics. Accepts 1/0/true/false/
# yes/no/on/off (case-insensitive). See docs/feature-flags.md for the full
# contract.

# RETRIEVAL_ENGINE_V2=off forces the legacy ranking.build_recall_response
# scorer on every request, bypassing the unified RetrievalEngine.
RETRIEVAL_ENGINE_V2=on

# STRUCTURED_FEEDBACK=off falls back to the v0.2.x audit-log feedback path.
STRUCTURED_FEEDBACK=on

# EVOLUTION_ENABLED=off makes the evolution cycle a no-op
# (status="disabled") so policy is effectively static.
EVOLUTION_ENABLED=on

# SHADOW_ENABLED=off skips the shadow-comparison stage of the evolution
# cycle. Useful for reproducible CI / evaluation runs.
SHADOW_ENABLED=on

# PASSWORD_TOTP_AUTH=off forces the legacy bearer-token login flow even
# when MEMORY_OS_PASSWORD is configured. PASSWORD_TOTP_AUTH=on (default)
# prefers password + TOTP when both are configured.
PASSWORD_TOTP_AUTH=on

# Optional. Path to a dotenv-style file to load at startup. If unset, the
# process environment is used directly.
# MEMORY_OS_ENV_FILE=/absolute/path/to/.env

# Ingestion settings. WORKSPACE_ROOT should point at the OpenClaw workspace
# that contains MEMORY.md and memory/*.md. The robust ingestion command uses
# checkpoint/resume and skip-existing by default, so interrupted full runs can
# be safely repeated.
# WORKSPACE_ROOT=/path/to/workspace
OLLAMA_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text
INGEST_EMBED_TIMEOUT=300

# Operator-specific taxonomy must be stored in a gitignored local JSON
# file. The public repository ships only a fictional schema example.
# Copy config/personal_taxonomy.example.json to
# config/personal_taxonomy.json and edit the local values. Never commit
# operator-specific names, brands, accounts, or keyword lists.
# MEMORY_OS_TAXONOMY_PATH=/absolute/path/to/personal_taxonomy.json

# ---------------------------------------------------------------------------
# v0.3.0 graduation policy evolution (G11)
# ---------------------------------------------------------------------------
# These keys feed the promotion / rollback governance loop (see
# docs/feedback-loop-roadmap.md). All values are read by the evolution
# runner; safe defaults preserve the previous "always-on" behaviour so a
# missing env var never silently changes governance semantics.
#
# MEMORY_OS_POLICY_DIR — directory holding the versioned policy files
#   (each policy version is a JSON blob; the runner picks the active one
#   from this directory). Defaults to ``config/policy`` under the project
#   root when unset.
# MEMORY_OS_SESSIONS_DB — absolute path to the SQLite store used for
#   session-scoped evaluation. Defaults to the value derived from
#   ``MEMORY_OS_RECALL_STATE_DIR`` (or ``$XDG_STATE_HOME``).
# MEMORY_OS_RECALL_DB — absolute path to the recall-feedback SQLite
#   store. Defaults to ``$MEMORY_OS_RECALL_STATE_DIR/openclaw-memory-os/
#   recall_feedback.db``. Setting this explicitly is useful when running
#   an isolated evaluation against a snapshot copy.
#
# PROMOTION_MODE — one of ``off``, ``manual``, ``guarded_auto``,
#   ``auto``. ``guarded_auto`` (default) requires every gate below to
#   pass before a candidate policy replaces the active one. ``manual``
#   surfaces the promotion decision to the dashboard without ever
#   flipping the active pointer; ``off`` disables the evolution cycle.
# AUTO_PROMOTION_MIN_QUERIES — minimum number of judged queries on the
#   candidate policy before promotion is allowed. Default 100.
# AUTO_PROMOTION_REQUIRED_PASSES — number of consecutive eval runs the
#   candidate must clear before promotion. Default 2.
# PROMOTION_COOLDOWN_DAYS — minimum number of days between two
#   consecutive successful promotions. Default 7.
# MAX_PROMOTIONS_PER_30_DAYS — safety cap on how many promotions may
#   land in any rolling 30-day window. Default 2.
# MAX_CONSECUTIVE_ROLLBACKS — when this many consecutive promotions are
#   rolled back, the runner locks itself into ``manual`` mode and pages
#   an operator. Default 2.

MEMORY_OS_POLICY_DIR=
MEMORY_OS_SESSIONS_DB=
MEMORY_OS_RECALL_DB=
PROMOTION_MODE=guarded_auto
AUTO_PROMOTION_MIN_QUERIES=100
AUTO_PROMOTION_REQUIRED_PASSES=2
PROMOTION_COOLDOWN_DAYS=7
MAX_PROMOTIONS_PER_30_DAYS=2
MAX_CONSECUTIVE_ROLLBACKS=2
